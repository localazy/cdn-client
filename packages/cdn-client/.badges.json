{
  "outputDir": ".github/badges",
  "badges": {
    "version": { "label": "npm", "value": "@version", "icon": "npm" },
    "coverage": {
      "label": "coverage",
      "value": "$BADGES_COVERAGE",
      "format": "percent",
      "icon": "vitest"
    },
    "size": {
      "label": "minzipped size",
      "value": "$BADGES_SIZE",
      "format": "bytes",
      "icon": "speed",
      "color": "43b816"
    },
    "maintainer": { "label": "maintainer", "value": "Localazy" },
    "license": { "label": "license", "value": "@license" }
  }
}
